generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum WorkMode {
  REMOTE
  OFFICE
  HYBRID
  FREELANCE
}

enum WorkStyle {
  CODING
  DEEP_FOCUS
  MEETINGS_HEAVY
  CREATIVE
  MIXED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  ACTIVE
  COMPLETED
  SKIPPED
  CANCELLED
}

enum FocusSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum BreakType {
  SHORT
  LONG
  EYE_REST
  STRETCH
  HYDRATION
  WALK
  BREATHING
}

enum BreakSessionStatus {
  SCHEDULED
  ACTIVE
  TAKEN
  SKIPPED
  MISSED
  CANCELLED
}

enum NotificationType {
  BREAK_REMINDER
  EYE_REST
  STRETCH
  DAILY_SUMMARY
  FOCUS_COMPLETE
  AI_SUMMARY_READY
  SUBSCRIPTION_UPDATE
}

enum NotificationStatus {
  UNREAD
  READ
  SENT
  FAILED
}

enum DailyPlanStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

model User {
  id                  String   @id @default(cuid())
  name                String?
  email               String   @unique
  passwordHash        String?
  avatarUrl           String?
  authProvider        AuthProvider @default(EMAIL)
  isEmailVerified     Boolean  @default(false)
  onboardingCompleted Boolean  @default(false)

  refreshTokens       RefreshToken[]
  onboardingResponse  OnboardingResponse?
  preferences         UserPreference?
  dailyPlans          DailyPlan[]
  tasks               Task[]
  focusSessions       FocusSession[]
  breakSessions       BreakSession[]
  notifications       Notification[]
  dailyAnalytics      DailyAnalytics[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OnboardingResponse {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  workMode               WorkMode
  workStyle              WorkStyle
  wellnessGoals          String[]
  breakPreference        String
  notificationPreference String
  workingDays            String[]
  workStartTime          String
  workEndTime            String
  timezone               String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_responses")
}

model UserPreference {
  id                        String          @id @default(cuid())
  userId                    String          @unique
  workMode                  WorkMode
  workStartTime             String
  workEndTime               String
  workingDays               String[]
  timezone                  String
  focusDurationMinutes      Int             @default(50)
  shortBreakDurationMinutes Int             @default(10)
  longBreakDurationMinutes  Int             @default(20)
  longBreakAfterSessions    Int             @default(4)
  eyeRestIntervalMinutes    Int             @default(25)
  stretchIntervalMinutes    Int             @default(90)
  notificationType          String
  soundEnabled              Boolean         @default(true)
  dailySummaryEnabled       Boolean         @default(false)
  theme                     ThemePreference @default(SYSTEM)
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user                      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model DailyPlan {
  id                    String          @id @default(cuid())
  userId                String
  planDate              DateTime
  status                DailyPlanStatus @default(PLANNED)
  totalPlannedMinutes   Int             @default(0)
  totalCompletedMinutes Int             @default(0)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks                 Task[]
  focusSessions         FocusSession[]

  @@unique([userId, planDate])
  @@index([userId])
  @@index([planDate])
  @@map("daily_plans")
}

model Task {
  id               String       @id @default(cuid())
  userId           String
  dailyPlanId      String?
  title            String
  description      String?
  priority         TaskPriority @default(MEDIUM)
  category         String?
  estimatedMinutes Int?
  actualMinutes    Int?
  dueTime          DateTime?
  status           TaskStatus   @default(PENDING)
  sortOrder        Int          @default(0)
  useForAiPlanning Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyPlan        DailyPlan?   @relation(fields: [dailyPlanId], references: [id], onDelete: SetNull)
  focusSessions    FocusSession[]

  @@index([userId])
  @@index([dailyPlanId])
  @@index([status])
  @@map("tasks")
}

model FocusSession {
  id                     String             @id @default(cuid())
  userId                 String
  taskId                 String?
  dailyPlanId            String?
  startedAt              DateTime           @default(now())
  endedAt                DateTime?
  pausedAt               DateTime?
  totalPausedSeconds     Int                @default(0)
  plannedDurationMinutes Int
  actualDurationMinutes  Int?
  status                 FocusSessionStatus @default(ACTIVE)
  moodBefore             String?
  moodAfter              String?
  distractionCount       Int                @default(0)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  task                   Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)
  dailyPlan              DailyPlan?         @relation(fields: [dailyPlanId], references: [id], onDelete: SetNull)
  breakSessions          BreakSession[]

  @@index([userId])
  @@index([taskId])
  @@index([status])
  @@index([startedAt])
  @@map("focus_sessions")
}

model BreakSession {
  id                     String             @id @default(cuid())
  userId                 String
  focusSessionId         String?
  breakType              BreakType
  startedAt              DateTime?
  endedAt                DateTime?
  plannedDurationMinutes Int
  actualDurationMinutes  Int?
  status                 BreakSessionStatus @default(SCHEDULED)
  suggestion             String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusSession           FocusSession?      @relation(fields: [focusSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([focusSessionId])
  @@index([status])
  @@map("break_sessions")
}

model Notification {
  id          String             @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  scheduledAt DateTime?
  sentAt      DateTime?
  readAt      DateTime?
  status      NotificationStatus @default(UNREAD)
  metadata    Json?
  createdAt   DateTime           @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@map("notifications")
}

model DailyAnalytics {
  id                         String   @id @default(cuid())
  userId                     String
  date                       DateTime
  totalFocusMinutes          Int      @default(0)
  totalBreakMinutes          Int      @default(0)
  tasksCompleted             Int      @default(0)
  tasksSkipped               Int      @default(0)
  breaksTaken                Int      @default(0)
  breaksSkipped              Int      @default(0)
  averageFocusSessionMinutes Int      @default(0)
  productivityScore          Int      @default(0)
  breakHealthScore           Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("daily_analytics")
}
