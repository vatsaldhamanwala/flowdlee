{
  "name": "flowdlee",
  "version": "1.0.0",
  "private": true,
  "description": "Flowdlee is a calm AI-ready workday planner and smart break reminder platform for IT professionals.",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "db:generate": "pnpm --filter web prisma generate",
    "db:push": "pnpm --filter web prisma db push",
    "db:studio": "pnpm --filter web prisma studio",
    "type-check": "pnpm --filter web exec tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "keywords": [
    "flowdlee",
    "productivity",
    "workday-planner",
    "focus",
    "break-reminder",
    "nextjs",
    "monorepo",
    "ai-planner"
  ],
  "author": "Vatsal Dhamanwala",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
